# =============================================================================
# Bifract Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# The bifract wizard generates this automatically during installation.
# All values shown below are the defaults.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bifract
POSTGRES_USER=bifract
POSTGRES_PASSWORD=bifract

# -----------------------------------------------------------------------------
# ClickHouse
# -----------------------------------------------------------------------------
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=logs
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
BIFRACT_PORT=8080
BIFRACT_MAX_QUERY_ROWS=10000

# Domain and base URL (used for alert webhook links, HTTPS via Caddy, etc.)
# BIFRACT_DOMAIN=bifract.example.com
# BIFRACT_BASE_URL=https://bifract.example.com

# Comma-separated list of allowed CORS origins.
BIFRACT_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Set to "true" when running behind HTTPS to enable Secure cookie flag and HSTS.
BIFRACT_SECURE_COOKIES=false

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# HMAC-SHA256 pepper applied to password hashes (defense-in-depth).
# Once set, do NOT change it or existing passwords will stop working.
# BIFRACT_PASSWORD_PEPPER=

# AES-256 key for encrypting feed tokens. Hex or base64 encoded, 32 bytes.
# Once set, do NOT change it or existing feed tokens become unreadable.
# BIFRACT_FEED_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Ingestion Pipeline
# -----------------------------------------------------------------------------
# Queue slots (each slot holds one batch, typically thousands of logs).
BIFRACT_INGEST_QUEUE_SIZE=500

# Number of worker goroutines draining the ingestion queue.
BIFRACT_INGEST_WORKERS=4

# Maximum request body size in bytes (default 200 MB).
BIFRACT_MAX_BODY_SIZE=209715200

# Token-bucket rate limiter for ingest endpoints (requests per second / burst).
BIFRACT_INGEST_RATE_LIMIT=10000
BIFRACT_INGEST_RATE_BURST=20000

# -----------------------------------------------------------------------------
# Alerts
# -----------------------------------------------------------------------------
# How often (in seconds) the background alert evaluator runs.
BIFRACT_ALERT_EVAL_INTERVAL=30

# -----------------------------------------------------------------------------
# Prometheus Metrics (optional, disabled by default)
# -----------------------------------------------------------------------------
# Set to "true" to enable the Prometheus metrics endpoint.
# Listens on a separate address so it can be firewalled independently.
# BIFRACT_METRICS_ENABLED=true
# BIFRACT_METRICS_ADDR=:9090

# -----------------------------------------------------------------------------
# LiteLLM (AI Chat - optional)
# -----------------------------------------------------------------------------
# LITELLM_URL=http://litellm:8000
# LITELLM_MASTER_KEY=

# API key for AI chat (Anthropic, OpenAI, etc). See litellm-config.yaml.
# LITELLM_API_KEY=

# -----------------------------------------------------------------------------
# Backup & Archives
# -----------------------------------------------------------------------------
# AES-256-GCM key for encrypting PostgreSQL backups and ClickHouse archives.
# Generated automatically by bifract. Hex-encoded, 32 bytes.
# Do NOT lose this key -- without it, backups and archives cannot be decrypted.
# BIFRACT_BACKUP_ENCRYPTION_KEY=

# S3-compatible storage for archives (optional, defaults to local disk).
# Works with AWS S3, MinIO, DigitalOcean Spaces, etc.
# BIFRACT_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# BIFRACT_S3_BUCKET=
# BIFRACT_S3_ACCESS_KEY=
# BIFRACT_S3_SECRET_KEY=
# BIFRACT_S3_REGION=nyc3

# -----------------------------------------------------------------------------
# MaxMind GeoIP Enrichment (optional, disabled by default)
# -----------------------------------------------------------------------------
# Requires a free MaxMind account. Enriches logs with geo/ASN data.
# MAXMIND_LICENSE_KEY=
# MAXMIND_ACCOUNT_ID=
# MAXMIND_EDITION_IDS=GeoLite2-City-CSV,GeoLite2-ASN-CSV
# MAXMIND_DATA_DIR=/data/maxmind

# -----------------------------------------------------------------------------
# OIDC Authentication (optional, disabled by default)
# -----------------------------------------------------------------------------
# Set BIFRACT_OIDC_ISSUER_URL and BIFRACT_OIDC_CLIENT_ID to enable SSO.
# BIFRACT_OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant}/v2.0
# BIFRACT_OIDC_CLIENT_ID=
# BIFRACT_OIDC_CLIENT_SECRET=
# BIFRACT_OIDC_REDIRECT_URL=              # Auto-derived from BIFRACT_BASE_URL if empty
# BIFRACT_OIDC_SCOPES=openid,profile,email
# BIFRACT_OIDC_DEFAULT_ROLE=user          # Role for auto-provisioned users
# BIFRACT_OIDC_ALLOWED_DOMAINS=           # Comma-separated, e.g. example.com,corp.co
# BIFRACT_OIDC_BUTTON_TEXT=Sign in with SSO
