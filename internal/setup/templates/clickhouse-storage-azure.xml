<?xml version="1.0"?>
<!--
  Azure Blob cold storage tier. Generated by bifract from
  BIFRACT_COLD_STORAGE_BACKEND=azure. Credentials are read from environment
  variables on the clickhouse service (from_env), so they live only in .env.
  Managed by the setup tooling: regenerated on reconfigure/upgrade.
-->
<clickhouse>
    <storage_configuration>
        <disks>
            <cold_azure>
                <type>azure_blob_storage</type>
                <storage_account_url from_env="BIFRACT_AZURE_STORAGE_URL"></storage_account_url>
                <container_name from_env="BIFRACT_AZURE_CONTAINER"></container_name>
                <account_name from_env="BIFRACT_AZURE_STORAGE_ACCOUNT"></account_name>
                <account_key from_env="BIFRACT_AZURE_STORAGE_KEY"></account_key>
            </cold_azure>
            <cold_cache>
                <type>cache</type>
                <disk>cold_azure</disk>
                <path>/var/lib/clickhouse/cold_cache/</path>
                <max_size from_env="BIFRACT_COLD_STORAGE_CACHE_SIZE">53687091200</max_size>
            </cold_cache>
        </disks>
        <policies>
            <tiered>
                <volumes>
                    <!-- Hot volume named 'default' so ALTER MODIFY storage_policy is accepted. -->
                    <default>
                        <disk>default</disk>
                    </default>
                    <cold>
                        <disk>cold_cache</disk>
                    </cold>
                </volumes>
                <move_factor>0.1</move_factor>
            </tiered>
        </policies>
    </storage_configuration>
</clickhouse>
