# Network policies enforce that all external traffic flows through Caddy.
# Only Caddy can reach Bifract, only Bifract can reach the databases.

# Default deny all ingress within the namespace
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: default-deny-ingress
  namespace: bifract
spec:
  podSelector: {}
  policyTypes:
    - Ingress
---
# Caddy: allow external traffic (LoadBalancer)
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-caddy-ingress
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app: caddy
  policyTypes:
    - Ingress
  ingress:
    - ports:
        - port: 80
        - port: 443
        - port: 8443
---
# Bifract: only accept traffic from Caddy pods
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-bifract-from-caddy
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app: bifract
  policyTypes:
    - Ingress
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app: caddy
      ports:
        - port: 8080
---
# LiteLLM: only accept traffic from Bifract pods
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-litellm-from-bifract
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app: litellm
  policyTypes:
    - Ingress
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app: bifract
      ports:
        - port: 8000
---
# PostgreSQL: only accept traffic from Bifract pods
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-postgres-from-bifract
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app: postgres
  policyTypes:
    - Ingress
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app: bifract
      ports:
        - port: 5432
---
# ClickHouse: allow Bifract connections and inter-node replication.
# The official ClickHouse operator labels pods with app.kubernetes.io/instance.
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-clickhouse-from-bifract
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/instance: bifract-ch-clickhouse
  policyTypes:
    - Ingress
  ingress:
    # Bifract app connections
    - from:
        - podSelector:
            matchLabels:
              app: bifract
      ports:
        - port: 9000
        - port: 8123
    # Inter-node replication and keeper connections
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/instance: bifract-ch-clickhouse
      ports:
        - port: 9000
        - port: 9009
        - port: 8123
---
# ClickHouse Keeper: only accept from CH nodes and other keepers
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: allow-keeper-from-clickhouse
  namespace: bifract
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/instance: bifract-keeper-keeper
  policyTypes:
    - Ingress
  ingress:
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/instance: bifract-ch-clickhouse
      ports:
        - port: 2181
        - port: 9181
    - from:
        - podSelector:
            matchLabels:
              app.kubernetes.io/instance: bifract-keeper-keeper
      ports:
        - port: 9181
