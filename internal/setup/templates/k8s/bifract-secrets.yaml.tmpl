apiVersion: v1
kind: Secret
metadata:
  name: bifract-secrets
  namespace: bifract
type: Opaque
stringData:
  POSTGRES_PASSWORD: "{{.PostgresPassword}}"
  CLICKHOUSE_PASSWORD: "{{.ClickHousePassword}}"
  CLICKHOUSE_PASSWORD_HASH: "{{.CHPasswordHash}}"
  PASSWORD_PEPPER: "{{.PasswordPepper}}"
  ADMIN_PASSWORD_HASH: "{{.AdminPasswordHash}}"
  FEED_ENCRYPTION_KEY: "{{.FeedEncryptionKey}}"
  BACKUP_ENCRYPTION_KEY: "{{.BackupEncryptionKey}}"
  LITELLM_MASTER_KEY: "{{.LiteLLMMasterKey}}"
  LITELLM_API_KEY: "{{index .UserSecrets "LITELLM_API_KEY"}}"
  S3_ENDPOINT: "{{index .UserSecrets "S3_ENDPOINT"}}"
  S3_BUCKET: "{{index .UserSecrets "S3_BUCKET"}}"
  S3_ACCESS_KEY: "{{index .UserSecrets "S3_ACCESS_KEY"}}"
  S3_SECRET_KEY: "{{index .UserSecrets "S3_SECRET_KEY"}}"
  S3_REGION: "{{index .UserSecrets "S3_REGION"}}"
  MAXMIND_LICENSE_KEY: "{{index .UserSecrets "MAXMIND_LICENSE_KEY"}}"
  MAXMIND_ACCOUNT_ID: "{{index .UserSecrets "MAXMIND_ACCOUNT_ID"}}"
  OIDC_ISSUER_URL: "{{index .UserSecrets "OIDC_ISSUER_URL"}}"
  OIDC_CLIENT_ID: "{{index .UserSecrets "OIDC_CLIENT_ID"}}"
  OIDC_CLIENT_SECRET: "{{index .UserSecrets "OIDC_CLIENT_SECRET"}}"
  OIDC_REDIRECT_URL: "{{index .UserSecrets "OIDC_REDIRECT_URL"}}"
  OIDC_SCOPES: "{{with index .UserSecrets "OIDC_SCOPES"}}{{.}}{{else}}openid,profile,email{{end}}"
  OIDC_DEFAULT_ROLE: "{{with index .UserSecrets "OIDC_DEFAULT_ROLE"}}{{.}}{{else}}user{{end}}"
  OIDC_ALLOWED_DOMAINS: "{{index .UserSecrets "OIDC_ALLOWED_DOMAINS"}}"
  OIDC_BUTTON_TEXT: "{{with index .UserSecrets "OIDC_BUTTON_TEXT"}}{{.}}{{else}}Sign in with SSO{{end}}"
