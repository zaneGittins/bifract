apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: bifract

resources:
  - namespace.yaml
  - clickhouse/clickhouse-installation.yaml
{{- if gt .CHShards 1}}
  - clickhouse/lb-service.yaml
{{- end}}
  - postgres/statefulset.yaml
  - bifract/deployment.yaml
  - bifract/configmap.yaml
  - bifract/secrets.yaml
  - caddy/deployment.yaml
  - caddy/configmap.yaml
  - caddy/log-shipper.yaml
  - litellm/deployment.yaml
  - litellm/configmap.yaml
{{- if .MTLSEnabled}}
  - caddy/mtls-ca.yaml
  - bifract/mtls-ca.yaml
{{- end}}
  - network-policies.yaml
