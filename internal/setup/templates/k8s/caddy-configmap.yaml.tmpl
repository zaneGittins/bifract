apiVersion: v1
kind: ConfigMap
metadata:
  name: caddy-config
  namespace: bifract
data:
  Caddyfile: |
    {
      admin off
    }

    {{.Domain}} {
{{- if .MTLSEnabled}}
      tls {
        client_auth {
          mode require_and_verify
          trusted_ca_cert_file /etc/caddy/client-ca/ca.pem
        }
      }
{{- end}}
      log {
        output file /var/log/caddy/access.log {
          roll_size 50MiB
          roll_keep 5
          roll_keep_for 168h
        }
        format json
      }
      header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
      }
      request_body {
        max_size 200MiB
      }
{{.IPBlock}}
      @ingest_main path /api/v1/ingest* /_bulk

      route {
        respond /api/v1/internal/* 403
{{- if .IPBlock}}
        respond @blocked 403
{{- end}}
        respond @ingest_main 403
        reverse_proxy bifract.bifract.svc.cluster.local:8080 {
          header_up X-Real-IP {remote_host}
          header_up X-Forwarded-For {remote_host}
          header_up X-Forwarded-Proto {scheme}
          transport http {
            dial_timeout 10s
            response_header_timeout 120s
          }
        }
      }
    }

    {{.Domain}}:8443 {
      log {
        output file /var/log/caddy/access.log {
          roll_size 50MiB
          roll_keep 5
          roll_keep_for 168h
        }
        format json
      }
      request_body {
        max_size 200MiB
      }
{{.IPBlockIngest}}
      @ingest path /api/v1/ingest* /_bulk
      @not_ingest not path /api/v1/ingest* /_bulk

      route {
{{- if .IPBlockIngest}}
        respond @blocked_ingest 403
{{- end}}
        respond @not_ingest 403
        log_skip
        reverse_proxy bifract.bifract.svc.cluster.local:8080 {
          header_up X-Real-IP {remote_host}
          header_up X-Forwarded-For {remote_host}
          header_up X-Forwarded-Proto {scheme}
          transport http {
            dial_timeout 10s
            response_header_timeout 120s
          }
        }
      }
    }
