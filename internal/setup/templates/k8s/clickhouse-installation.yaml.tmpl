apiVersion: clickhouse.com/v1alpha1
kind: KeeperCluster
metadata:
  name: bifract-keeper
  namespace: bifract
spec:
  replicas: 1
  dataVolumeClaimSpec:
    accessModes:
      - ReadWriteOnce
    resources:
      requests:
        storage: 10Gi
  containerTemplate:
    image:
      repository: clickhouse/clickhouse-keeper
      tag: "26.2-alpine"
    resources:
      requests:
        cpu: {{.CHKeeper.CPURequest}}
        memory: {{.CHKeeper.MemRequest}}
      limits:
        cpu: "{{.CHKeeper.CPULimit}}"
        memory: {{.CHKeeper.MemLimit}}
---
apiVersion: clickhouse.com/v1alpha1
kind: ClickHouseCluster
metadata:
  name: bifract-ch
  namespace: bifract
spec:
  shards: {{.CHShards}}
  replicas: {{.CHReplicas}}
  keeperClusterRef:
    name: bifract-keeper
  podTemplate:
    securityContext:
      fsGroupChangePolicy: OnRootMismatch
      runAsUser: 101
      runAsGroup: 101
      fsGroup: 101
      runAsNonRoot: true
    affinity:
      podAntiAffinity:
        preferredDuringSchedulingIgnoredDuringExecution:
          - weight: 100
            podAffinityTerm:
              labelSelector:
                matchLabels:
                  app: bifract-ch-clickhouse
              topologyKey: kubernetes.io/hostname
{{- if or (eq .ColdStorageRender "s3") (eq .ColdStorageRender "azure")}}
    volumes:
      - name: cold-storage-config
        secret:
          secretName: bifract-ch-storage
{{- end}}
  dataVolumeClaimSpec:
    accessModes:
      - ReadWriteOnce
    resources:
      requests:
        storage: {{.CHStorageStr}}
  containerTemplate:
    image:
      repository: clickhouse/clickhouse-server
      tag: "26.2-alpine"
    resources:
      requests:
        cpu: "{{.CH.CPURequest}}"
        memory: {{.CH.MemRequest}}
      limits:
        cpu: "{{.CH.CPULimit}}"
        memory: {{.CH.MemLimit}}
{{- if or (eq .ColdStorageRender "s3") (eq .ColdStorageRender "azure")}}
    # Cold storage tier config, mounted from the bifract-ch-storage Secret below.
    volumeMounts:
      - name: cold-storage-config
        mountPath: /etc/clickhouse-server/config.d/storage.xml
        subPath: storage.xml
{{- end}}
  settings:
    defaultUserPassword:
      passwordType: password_sha256_hex
      secret:
        name: bifract-secrets
        key: CLICKHOUSE_PASSWORD_HASH
    extraUsersConfig:
      profiles:
        default:
          distributed_background_insert_batch: 1
          distributed_background_insert_split_batch_on_failure: 1
          distributed_background_insert_max_sleep_time_ms: 5000
{{if eq .ColdStorageRender "s3"}}
---
# Cold storage tier config (S3), mounted into the ClickHouse pods' config.d.
# Rendered from the COLD_STORAGE_*/S3_* secret values; re-rendered on reconfigure/upgrade.
apiVersion: v1
kind: Secret
metadata:
  name: bifract-ch-storage
  namespace: bifract
type: Opaque
stringData:
  storage.xml: |
    <clickhouse>
        <storage_configuration>
            <disks>
                <cold_obj>
                    <type>s3</type>
                    <endpoint>{{index .UserSecrets "COLD_STORAGE_ENDPOINT"}}</endpoint>
                    <access_key_id>{{index .UserSecrets "S3_ACCESS_KEY"}}</access_key_id>
                    <secret_access_key>{{index .UserSecrets "S3_SECRET_KEY"}}</secret_access_key>
                    <region>{{index .UserSecrets "S3_REGION"}}</region>
                </cold_obj>
                <cold_cache>
                    <type>cache</type>
                    <disk>cold_obj</disk>
                    <path>/var/lib/clickhouse/cold_cache/</path>
                    <max_size>{{with index .UserSecrets "COLD_STORAGE_CACHE_SIZE"}}{{.}}{{else}}53687091200{{end}}</max_size>
                </cold_cache>
            </disks>
            <policies>
                <tiered>
                    <volumes>
                        <default><disk>default</disk></default>
                        <cold><disk>cold_cache</disk></cold>
                    </volumes>
                    <move_factor>0.1</move_factor>
                </tiered>
            </policies>
        </storage_configuration>
    </clickhouse>
{{end}}
{{- if eq .ColdStorageRender "azure"}}
---
# Cold storage tier config (Azure Blob), mounted into the ClickHouse pods' config.d.
# Rendered from the COLD_STORAGE_*/AZURE_* secret values; re-rendered on reconfigure/upgrade.
apiVersion: v1
kind: Secret
metadata:
  name: bifract-ch-storage
  namespace: bifract
type: Opaque
stringData:
  storage.xml: |
    <clickhouse>
        <storage_configuration>
            <disks>
                <cold_obj>
                    <type>azure_blob_storage</type>
                    <storage_account_url>{{index .UserSecrets "AZURE_STORAGE_URL"}}</storage_account_url>
                    <container_name>{{index .UserSecrets "AZURE_CONTAINER"}}</container_name>
                    <account_name>{{index .UserSecrets "AZURE_STORAGE_ACCOUNT"}}</account_name>
                    <account_key>{{index .UserSecrets "AZURE_STORAGE_KEY"}}</account_key>
                </cold_obj>
                <cold_cache>
                    <type>cache</type>
                    <disk>cold_obj</disk>
                    <path>/var/lib/clickhouse/cold_cache/</path>
                    <max_size>{{with index .UserSecrets "COLD_STORAGE_CACHE_SIZE"}}{{.}}{{else}}53687091200{{end}}</max_size>
                </cold_cache>
            </disks>
            <policies>
                <tiered>
                    <volumes>
                        <default><disk>default</disk></default>
                        <cold><disk>cold_cache</disk></cold>
                    </volumes>
                    <move_factor>0.1</move_factor>
                </tiered>
            </policies>
        </storage_configuration>
    </clickhouse>
{{- end}}
