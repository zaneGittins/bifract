apiVersion: apps/v1
kind: Deployment
metadata:
  name: caddy
  namespace: bifract
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: caddy
  template:
    metadata:
      labels:
        app: caddy
    spec:
      securityContext:
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: caddy
          image: caddy:2-alpine
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
              add: ["NET_BIND_SERVICE"]
          ports:
            - containerPort: 443
              name: https
            - containerPort: 8443
              name: ingest
            - containerPort: 80
              name: http
          volumeMounts:
            - name: caddyfile
              mountPath: /etc/caddy/Caddyfile
              subPath: Caddyfile
            - name: caddy-data
              mountPath: /data
            - name: caddy-logs
              mountPath: /var/log/caddy
{{- if .MTLSEnabled}}
            - name: client-ca
              mountPath: /etc/caddy/client-ca
              readOnly: true
{{- end}}
          livenessProbe:
            tcpSocket:
              port: 443
            initialDelaySeconds: 10
            periodSeconds: 30
            timeoutSeconds: 5
          readinessProbe:
            tcpSocket:
              port: 443
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 3
          resources:
            requests:
              cpu: {{.CaddyRes.CPURequest}}
              memory: {{.CaddyRes.MemRequest}}
            limits:
              cpu: "{{.CaddyRes.CPULimit}}"
              memory: {{.CaddyRes.MemLimit}}
        - name: log-shipper
          image: alpine:3
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
          command: ["/bin/sh", "-c"]
          args:
            - |
              apk add --no-cache jq curl > /dev/null 2>&1
              exec /scripts/ship-logs.sh
          env:
            - name: BIFRACT_INGEST_URL
              value: "http://bifract.bifract.svc.cluster.local:8080/api/v1/internal/ingest/system"
          volumeMounts:
            - name: caddy-logs
              mountPath: /var/log/caddy
              readOnly: true
            - name: log-shipper-script
              mountPath: /scripts
          resources:
            requests:
              cpu: {{.CaddyShipper.CPURequest}}
              memory: {{.CaddyShipper.MemRequest}}
            limits:
              cpu: {{.CaddyShipper.CPULimit}}
              memory: {{.CaddyShipper.MemLimit}}
      volumes:
        - name: caddyfile
          configMap:
            name: caddy-config
        - name: caddy-data
          persistentVolumeClaim:
            claimName: caddy-data
        - name: caddy-logs
          emptyDir: {}
        - name: log-shipper-script
          configMap:
            name: caddy-log-shipper
            defaultMode: 0755
{{- if .MTLSEnabled}}
        - name: client-ca
          secret:
            secretName: caddy-mtls-ca
{{- end}}
---
apiVersion: v1
kind: Service
metadata:
  name: caddy
  namespace: bifract
spec:
  type: LoadBalancer
  externalTrafficPolicy: Local
  ports:
    - port: 443
      targetPort: 443
      name: https
    - port: 8443
      targetPort: 8443
      name: ingest
    - port: 80
      targetPort: 80
      name: http
  selector:
    app: caddy
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: caddy-data
  namespace: bifract
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
