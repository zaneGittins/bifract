apiVersion: v1
kind: Service
metadata:
  name: bifract-ch-clickhouse-lb
  namespace: bifract
spec:
  type: ClusterIP
  selector:
    clickhouse.com/role: clickhouse-server
  ports:
    - name: native
      port: 9000
      targetPort: 9000
    - name: native-alt
      port: 9001
      targetPort: 9001
    - name: http
      port: 8123
      targetPort: 8123
