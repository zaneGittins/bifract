<?xml version="1.0"?>
<!--
  S3 / S3-compatible cold storage tier. Generated by bifract from
  BIFRACT_COLD_STORAGE_BACKEND=s3. Credentials are read from environment
  variables on the clickhouse service (from_env), so they live only in .env.
  Managed by the setup tooling: regenerated on reconfigure/upgrade.
-->
<clickhouse>
    <storage_configuration>
        <disks>
            <cold_s3>
                <type>s3</type>
                <endpoint from_env="BIFRACT_COLD_STORAGE_ENDPOINT"></endpoint>
                <access_key_id from_env="BIFRACT_S3_ACCESS_KEY"></access_key_id>
                <secret_access_key from_env="BIFRACT_S3_SECRET_KEY"></secret_access_key>
                <region from_env="BIFRACT_S3_REGION"></region>
            </cold_s3>
            <cold_cache>
                <type>cache</type>
                <disk>cold_s3</disk>
                <path>/var/lib/clickhouse/cold_cache/</path>
                <max_size from_env="BIFRACT_COLD_STORAGE_CACHE_SIZE">53687091200</max_size>
            </cold_cache>
        </disks>
        <policies>
            <tiered>
                <volumes>
                    <!-- Hot volume named 'default' so ALTER MODIFY storage_policy is accepted. -->
                    <default>
                        <disk>default</disk>
                    </default>
                    <cold>
                        <disk>cold_cache</disk>
                    </cold>
                </volumes>
                <move_factor>0.1</move_factor>
            </tiered>
        </policies>
    </storage_configuration>
</clickhouse>
